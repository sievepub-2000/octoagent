# OctoAgent independent execution worker environment.
# Install to /etc/octoagent/execution-worker.env with owner root:root and mode 0600.

OCTO_EXECUTION_WORKER_HOST=127.0.0.1
OCTO_EXECUTION_WORKER_PORT=19812
OCTO_EXECUTION_WORKER_NODE_ID=worker-local-1
OCTO_EXECUTION_WORKER_CAPACITY=4
OCTO_EXECUTION_WORKER_CALLBACK_RETRIES=3

# Must match the dispatch_token/callback_token registered with the gateway.
OCTO_EXECUTION_WORKER_TOKEN=replace-with-a-long-random-token
