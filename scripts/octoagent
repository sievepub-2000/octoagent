#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
    LINK_TARGET="$(readlink "$SCRIPT_PATH")"
    if [[ "$LINK_TARGET" = /* ]]; then
        SCRIPT_PATH="$LINK_TARGET"
    else
        SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/$LINK_TARGET"
    fi
done

REPO_ROOT="${OCTOAGENT_HOME:-$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)}"
cd "$REPO_ROOT"

usage() {
    cat <<USAGE
Usage: octoagent [command] [options]

Commands:
  start              Start the full OctoAgent stack. This is the default.
  stop               Stop the OctoAgent stack.
  restart            Restart the OctoAgent stack.
  status             Show service status when systemd owns the runtime.
  open               Open the local WebUI after it is ready.
  configure          Configure repository runtime state, especially default model.
  ports              Print the OctoAgent port map.
  install            Run the one-command installer from this checkout.
  service-install    Install or refresh the systemd unit and CLI symlink.
  doctor             Run dependency checks and a lightweight FAISS import check.
  help               Show this help.

Examples:
  octoagent
  octoagent configure
  octoagent configure --default-model qwen3.6-35b-a3b-q8-mm-prod --yes
  octoagent ports
  octoagent install --mode service --start
USAGE
}

systemd_available() {
    command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files octoagent-local.service >/dev/null 2>&1
}

start_stack() {
    if systemd_available; then
        "$REPO_ROOT/scripts/start-octoagent.sh" start
    else
        "$REPO_ROOT/scripts/start-daemon.sh" --prod
    fi
}

stop_stack() {
    if systemd_available; then
        "$REPO_ROOT/scripts/start-octoagent.sh" stop
    else
        "$REPO_ROOT/scripts/stop-services.sh"
    fi
}

restart_stack() {
    if systemd_available; then
        "$REPO_ROOT/scripts/start-octoagent.sh" restart
    else
        "$REPO_ROOT/scripts/stop-services.sh" || true
        "$REPO_ROOT/scripts/start-daemon.sh" --prod
    fi
}

print_ports() {
    # shellcheck disable=SC1091
    source "$REPO_ROOT/scripts/port-layout.sh"
    cat <<PORTS
OctoAgent port map

| Port | Variable | Component | Bind / exposure | Notes |
| --- | --- | --- | --- | --- |
| ${OCTO_NGINX_PORT} | OCTO_NGINX_PORT | nginx ingress | ${OCTO_NGINX_BIND_HOST} | Unified WebUI and API entrypoint: ${OCTO_PUBLIC_BASE_URL} |
| ${OCTO_GATEWAY_PORT} | OCTO_GATEWAY_PORT | FastAPI gateway | 127.0.0.1 | REST APIs, auth proxy, model/config/tool endpoints |
| ${OCTO_LANGGRAPH_PORT} | OCTO_LANGGRAPH_PORT | LangGraph runtime | 127.0.0.1 | Agent run and stream runtime |
| ${OCTO_FRONTEND_PORT} | OCTO_FRONTEND_PORT | Next.js frontend | 127.0.0.1 | Internal frontend target behind nginx |
| ${OCTO_PROVISIONER_PORT} | OCTO_PROVISIONER_PORT | Sandbox provisioner | optional | Docker/Kubernetes provisioner mode only |
| ${OCTO_TTYD_PORT} | OCTO_TTYD_PORT | ttyd terminal | 127.0.0.1 | Disabled by default; set OCTOAGENT_MANAGE_TTYD=1 for an explicit local terminal bridge |
| ${OCTO_SANDBOX_BASE_PORT}+ | OCTO_SANDBOX_BASE_PORT | Sandbox containers | dynamic | Per-sandbox ports allocated from this base |
| 19812 | OCTO_EXECUTION_WORKER_PORT | Execution worker | optional | Only used by the distributed worker service |
| 19814 | LISTEN_PORT | Generic webhook bridge | optional | Example external bridge listener |
| 19880 / 19882 / 19884 | NapCat / OneBot | QQ channel bridge | optional | QQ/NapCat ports; later communication channels should use 19880 + 10*n blocks |
PORTS
}

configure_runtime() {
    local default_model=""
    local yes="0"
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --default-model)
                default_model="${2:?--default-model requires a value}"
                shift 2
                ;;
            --yes|-y)
                yes="1"
                shift
                ;;
            --help|-h)
                echo "Usage: octoagent configure [--default-model NAME] [--yes]"
                return 0
                ;;
            *)
                echo "Unknown configure option: $1" >&2
                return 2
                ;;
        esac
    done

    if [ ! -f "$REPO_ROOT/config.yaml" ] && [ -f "$REPO_ROOT/config.example.yaml" ]; then
        cp "$REPO_ROOT/config.example.yaml" "$REPO_ROOT/config.yaml"
        echo "Created config.yaml from config.example.yaml"
    fi

    local python_bin="$REPO_ROOT/backend/.venv/bin/python"
    if [ ! -x "$python_bin" ]; then
        python_bin="$(command -v python3 || command -v python)"
    fi

    OCTOAGENT_CONFIGURE_DEFAULT_MODEL="$default_model" \
    OCTOAGENT_CONFIGURE_YES="$yes" \
    "$python_bin" - <<'PY'
from __future__ import annotations

import json
import os
import re
from datetime import datetime, timezone
from pathlib import Path

repo = Path.cwd()
config_path = repo / "config.yaml"
setup_path = repo / "workspace" / "env" / "setup.json"

def model_names_from_config() -> list[str]:
    if not config_path.exists():
        return []
    text = config_path.read_text(encoding="utf-8")
    names: list[str] = []
    try:
        import yaml  # type: ignore
        data = yaml.safe_load(text) or {}
        if isinstance(data, dict):
            for item in data.get("models") or []:
                if isinstance(item, dict) and item.get("name"):
                    names.append(str(item["name"]))
    except Exception:
        for match in re.finditer(r"(?m)^\s*-\s+name:\s*['\"]?([^'\"#\n]+)", text):
            value = match.group(1).strip()
            if value:
                names.append(value)
    return names

models = model_names_from_config()
chosen = os.environ.get("OCTOAGENT_CONFIGURE_DEFAULT_MODEL", "").strip()
yes = os.environ.get("OCTOAGENT_CONFIGURE_YES") == "1"

if not chosen and models and not yes:
    print("Available models:")
    for index, name in enumerate(models, start=1):
        print(f"  {index}. {name}")
    answer = input(f"Default model [1/{models[0]}]: ").strip()
    if answer.isdigit() and 1 <= int(answer) <= len(models):
        chosen = models[int(answer) - 1]
    else:
        chosen = answer or models[0]
elif not chosen and models:
    chosen = models[0]

if not chosen and not yes:
    chosen = input("Default model name: ").strip()
if not chosen and yes:
    print("No default model configured; run `octoagent configure` after adding models to config.yaml.")
if not chosen and not yes:
    raise SystemExit("default model is required")
if models and chosen and chosen not in models:
    raise SystemExit(f"default model {chosen!r} is not present in config.yaml models")

workspace = repo / "workspace"
layout = {
    "default_dir": str(workspace / "default"),
    "env_dir": str(workspace / "env"),
    "workflow_dir": str(workspace / "workflow"),
    "taskwork_dir": str(workspace / "workflow" / "taskwork"),
}
for value in layout.values():
    Path(value).mkdir(parents=True, exist_ok=True)

state: dict[str, object] = {}
if setup_path.exists():
    try:
        raw = json.loads(setup_path.read_text(encoding="utf-8"))
        if isinstance(raw, dict):
            state.update(raw)
    except Exception:
        pass
state.update(
    {
        "workspace_path": str(workspace),
        "default_model": chosen,
        "sandbox_mode": str(state.get("sandbox_mode") or "local"),
        "layout": layout,
        "updated_at": datetime.now(timezone.utc).isoformat(),
    }
)
state.setdefault("created_at", state["updated_at"])
state.setdefault("directories_created", [])
setup_path.parent.mkdir(parents=True, exist_ok=True)
setup_path.write_text(json.dumps(state, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
print(f"Configured default_model={chosen}")
print(f"Setup state: {setup_path}")
PY
}

doctor() {
    "$REPO_ROOT/scripts/check.sh"
    "$REPO_ROOT/backend/.venv/bin/python" - <<'PY'
import faiss
import importlib.metadata as md
print("faiss-cpu", md.version("faiss-cpu"), faiss.__file__)
PY
}


# --- Phase 5 (2026-05-26): logs + config verbs ---
print_logs() {
    local follow=0 lines=200 component=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            -f|--follow) follow=1; shift ;;
            -n|--lines) lines="${2:?--lines requires a value}"; shift 2 ;;
            --component) component="${2:?--component requires a value}"; shift 2 ;;
            -h|--help)
                cat <<HELP
Usage: octoagent logs [--follow|-f] [--lines N] [--component NAME]

  --follow, -f         Tail follow (Ctrl-C to stop)
  --lines, -n N        Show last N lines (default 200)
  --component NAME     One of: gateway | langgraph | frontend | nginx | service
                       Default: aggregates the service journal.
HELP
                return 0
                ;;
            *) echo "Unknown logs option: $1" >&2; return 2 ;;
        esac
    done

    local log_dir="$REPO_ROOT/logs"
    local target=""
    case "$component" in
        gateway)   target="$log_dir/gateway.log" ;;
        langgraph) target="$log_dir/langgraph.log" ;;
        frontend)  target="$log_dir/frontend.log" ;;
        nginx)     target="$log_dir/nginx.log" ;;
        ""|service)
            if systemd_available; then
                if [ "$follow" = "1" ]; then
                    exec journalctl -u octoagent-local.service -n "$lines" -f --no-pager
                else
                    exec journalctl -u octoagent-local.service -n "$lines" --no-pager
                fi
            fi
            target="$log_dir/service.log"
            ;;
        *) echo "Unknown component: $component" >&2; return 2 ;;
    esac

    if [ ! -f "$target" ]; then
        echo "Log file not found: $target" >&2
        return 1
    fi
    if [ "$follow" = "1" ]; then
        exec tail -n "$lines" -F "$target"
    else
        tail -n "$lines" "$target"
    fi
}

print_config() {
    local subcmd="${1:-show}"
    case "$subcmd" in
        show|""|get)
            local key="${2:-}"
            local base="${OCTOAGENT_PUBLIC_BASE_URL:-http://127.0.0.1:19800}"
            local body
            body="$(curl -fsS "$base/api/runtime/effective-config" 2>/dev/null || true)"
            if [ -z "$body" ]; then
                echo "error: cannot reach $base/api/runtime/effective-config -- is OctoAgent running?" >&2
                return 1
            fi
            if [ -n "$key" ]; then
                printf '%s' "$body" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); v=d
for p in '${key}'.split('.'):
    v = v.get(p, {}) if isinstance(v, dict) else None
print(json.dumps(v, ensure_ascii=False, indent=2))"
            else
                printf '%s' "$body" | python3 -m json.tool
            fi
            ;;
        -h|--help|help)
            cat <<HELP
Usage: octoagent config <subcommand>

Subcommands:
  show           Pretty-print the live effective-config snapshot (default)
  get KEY        Print one dotted-path key (e.g. ports.OCTO_GATEWAY_PORT)
HELP
            ;;
        *) echo "Unknown config subcommand: $subcmd" >&2; return 2 ;;
    esac
}

install_desktop_shortcut() {
    "$REPO_ROOT/scripts/install-desktop-shortcut.sh" "$@"
}
# --- end Phase 5 additions ---

command_name="${1:-start}"
if [ "$#" -gt 0 ]; then
    shift
fi

case "$command_name" in
    start) start_stack "$@" ;;
    stop) stop_stack "$@" ;;
    restart) restart_stack "$@" ;;
    status) "$REPO_ROOT/scripts/start-octoagent.sh" status ;;
    open) "$REPO_ROOT/scripts/start-octoagent.sh" open ;;
    configure) configure_runtime "$@" ;;
    ports) print_ports ;;
    install) "$REPO_ROOT/scripts/install-octoagent.sh" "$@" ;;
    service-install) "$REPO_ROOT/scripts/install-octoagent.sh" --mode service --skip-bootstrap "$@" ;;
    logs) print_logs "$@" ;;
    config) print_config "$@" ;;
    desktop-shortcut) install_desktop_shortcut "$@" ;;
    doctor) doctor ;;
    drain) cd "$REPO_ROOT/backend" && exec ./.venv/bin/python -c "import asyncio,json; from src.harness.dispatcher import drain_self; print(json.dumps(asyncio.run(drain_self()), indent=2))" ;;
    help|--help|-h) usage ;;
    *) echo "Unknown command: $command_name" >&2; usage >&2; exit 2 ;;
esac
