# Frontend / Better Auth
# Required for production `pnpm build` in `frontend/`.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_BASE_URL=http://localhost:19880
BETTER_AUTH_GITHUB_CLIENT_ID=
BETTER_AUTH_GITHUB_CLIENT_SECRET=

# Optional frontend runtime routing
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:19882
NEXT_PUBLIC_LANGGRAPH_BASE_URL=http://localhost:19884
NEXT_PUBLIC_LOCAL_FRONTEND_PORT=19886
NEXT_PUBLIC_LOCAL_GATEWAY_PORT=19882
NEXT_PUBLIC_LOCAL_LANGGRAPH_PORT=19884
NEXT_PUBLIC_LOCAL_INGRESS_PORT=19880
NEXT_PUBLIC_STATIC_WEBSITE_ONLY=

# TAVILY API Key
TAVILY_API_KEY=your-tavily-api-key

# Jina API Key
JINA_API_KEY=your-jina-api-key

# InfoQuest API Key
INFOQUEST_API_KEY=your-infoquest-api-key
# CORS Origins (comma-separated) - e.g., http://localhost:19830,http://localhost:19880
# CORS_ORIGINS=http://localhost:19830,http://localhost:19880

# Optional:
# FIRECRAWL_API_KEY=your-firecrawl-api-key
# VOLCENGINE_API_KEY=your-volcengine-api-key
# OPENAI_API_KEY=your-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# NOVITA_API_KEY=your-novita-api-key  # OpenAI-compatible, see https://novita.ai
# GITHUB_OAUTH_TOKEN=your-github-oauth-token
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret

# SLACK_BOT_TOKEN=your-slack-bot-token
# SLACK_APP_TOKEN=your-slack-app-token
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Production governance hardening
# Generate each token with: openssl rand -hex 32
OCTO_OPERATOR_TOKEN=
OCTO_EXECUTION_WORKER_TOKEN=
OCTO_OPERATOR_AUDIT_SECRET=
OCTO_RUNTIME_MAX_RUNNING_RUN_AGE_SECONDS=3600

# Built-in user registration and trusted-device auth
# Codes expire after 10 minutes. Without SMTP, codes are logged for local development.
OCTO_SMTP_HOST=
OCTO_SMTP_PORT=587
OCTO_SMTP_USERNAME=
OCTO_SMTP_PASSWORD=
OCTO_SMTP_FROM=
OCTO_SMTP_TLS=1
OCTO_AUTH_DEV_EXPOSE_CODES=0

# Low-privilege silent maintenance agent
OCTO_GENERIC_AGENT_ENABLED=1
OCTO_GENERIC_AGENT_INTERVAL_SECONDS=1800
OCTO_GENERIC_AGENT_STARTUP_DELAY_SECONDS=120
