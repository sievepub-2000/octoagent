ARG NODE_RUNTIME_IMAGE=node:22-bookworm-slim
ARG PYTHON_BASE_IMAGE=python:3.12-slim
ARG DOCKER_CLI_IMAGE=docker:cli
ARG UV_IMAGE=ghcr.io/astral-sh/uv:0.7.20
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
FROM ${NODE_RUNTIME_IMAGE} AS node-runtime

FROM ${DOCKER_CLI_IMAGE} AS docker-cli
FROM ${UV_IMAGE} AS uv-runtime

FROM ${PYTHON_BASE_IMAGE} AS backend

ARG OCTOAGENT_UID=1000
ARG OCTOAGENT_GID=1000

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HTTP_PROXY=${HTTP_PROXY} \
    HTTPS_PROXY=${HTTPS_PROXY} \
    NO_PROXY=${NO_PROXY} \
    http_proxy=${HTTP_PROXY} \
    https_proxy=${HTTPS_PROXY} \
    no_proxy=${NO_PROXY} \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/app/backend/.venv \
    HOME=/tmp \
    PATH=/app/backend/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    packages="bash ca-certificates curl git build-essential passwd postgresql-client redis-tools"; \
    for attempt in 1 2 3 4 5; do \
      apt-get update -o Acquire::Retries=5 -o Acquire::http::Pipeline-Depth=0 && \
      apt-get install -y --download-only --no-install-recommends \
        -o Acquire::Retries=5 -o Acquire::http::Pipeline-Depth=0 \
        $packages && \
      break; \
      if [ "$attempt" = "5" ]; then exit 1; fi; \
      sleep "$((attempt * 5))"; \
    done; \
    apt-get install -y --no-install-recommends --no-download $packages; \
    rm -rf /var/lib/apt/lists/*

COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=uv-runtime /uv /uvx /usr/local/bin/
COPY --from=node-runtime /usr/local/bin/node /usr/local/bin/node
COPY --from=node-runtime /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -sf /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm \
    && ln -sf /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx \
    && node --version \
    && npm --version \
    && uv --version

WORKDIR /app
RUN mkdir -p /app/backend
COPY backend/pyproject.toml backend/uv.lock backend/README.md ./backend/

RUN --mount=type=cache,target=/root/.cache/uv \
    cd /app/backend && uv sync --frozen --no-dev --no-install-project

# Browser automation needs the shared libraries below. Keep this separate from
# the compiler/dependency layer so changing browser support does not invalidate
# the expensive Python wheel cache.
RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    browser_packages="libglib2.0-0t64 libnss3 libnspr4 libatk1.0-0t64 libatk-bridge2.0-0t64 \
      libcups2t64 libdrm2 libdbus-1-3 libxcb1 libxkbcommon0 libxcomposite1 \
      libxdamage1 libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 libcairo2 libasound2t64"; \
    for attempt in 1 2 3 4 5; do \
      apt-get update -o Acquire::Retries=5 -o Acquire::http::Pipeline-Depth=0 && \
      apt-get install -y --no-install-recommends \
        -o Acquire::Retries=5 -o Acquire::http::Pipeline-Depth=0 \
        $browser_packages && \
      break; \
      if [ "$attempt" = "5" ]; then exit 1; fi; \
      sleep "$((attempt * 5))"; \
    done; \
    rm -rf /var/lib/apt/lists/*

# Starlette prefers httpx2 for its test-client compatibility path. Keep it in
# the production runtime so the health/doctor checks do not emit a deprecation
# warning even though the main project does not otherwise depend on it.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --python /app/backend/.venv/bin/python httpx2==2.6.0

# Install Readability.js at build time. The Python wrapper otherwise tries a
# runtime npm install into root-owned site-packages, which fails under the
# unprivileged service user and silently degrades every web read to fallback
# extraction.
RUN --mount=type=cache,target=/root/.npm \
    cd /app/backend/.venv/lib/python3.12/site-packages/readabilipy/javascript \
    && npm install --omit=dev --loglevel=error --no-fund --no-audit

COPY runtime/tools/mcp/package.json runtime/tools/mcp/package-lock.json ./runtime/tools/mcp/
RUN --mount=type=cache,target=/root/.npm \
    cd /app/runtime/tools/mcp && npm ci --omit=dev --loglevel=error --no-fund --no-audit

COPY backend ./backend
COPY skills ./skills
COPY tools/hooks ./tools/hooks
COPY runtime/catalogs ./runtime/catalogs
COPY --from=docker-cli /usr/local/libexec/docker/cli-plugins /usr/local/libexec/docker/cli-plugins

RUN mkdir -p /app/logs /app/tmp /app/runtime/cache /app/runtime/logs \
    /app/runtime/system_tools /app/workspace/env /app/workspace/default \
    && groupadd --gid "$OCTOAGENT_GID" octoagent \
    && useradd --uid "$OCTOAGENT_UID" --gid "$OCTOAGENT_GID" --home-dir /tmp --no-create-home octoagent \
    && install -d -o "$OCTOAGENT_UID" -g "$OCTOAGENT_GID" /app/runtime/tools/npm-cache

WORKDIR /app
USER octoagent
EXPOSE 19802 19804
CMD ["bash", "-lc", "cd /app/backend && /app/backend/.venv/bin/uvicorn src.gateway.app:app --host 0.0.0.0 --port ${OCTO_GATEWAY_PORT:-19802}"]
