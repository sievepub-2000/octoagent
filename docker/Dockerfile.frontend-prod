ARG NODE_FRONTEND_IMAGE=node:22-alpine
FROM ${NODE_FRONTEND_IMAGE} AS frontend

ARG NPM_REGISTRY=https://registry.npmjs.org
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    HTTP_PROXY=${HTTP_PROXY} \
    HTTPS_PROXY=${HTTPS_PROXY} \
    NO_PROXY=${NO_PROXY} \
    http_proxy=${HTTP_PROXY} \
    https_proxy=${HTTPS_PROXY} \
    no_proxy=${NO_PROXY} \
    NPM_CONFIG_UPDATE_NOTIFIER=false \
    BETTER_AUTH_SECRET=docker-build-placeholder-change-at-runtime \
    BETTER_AUTH_BASE_URL=http://localhost:19800 \
    NEXT_PUBLIC_BACKEND_BASE_URL= \
    NEXT_PUBLIC_LANGGRAPH_BASE_URL= \
    NEXT_PUBLIC_LOCAL_FRONTEND_PORT=19806 \
    NEXT_PUBLIC_LOCAL_GATEWAY_PORT=19802 \
    NEXT_PUBLIC_LOCAL_LANGGRAPH_PORT=19804 \
    NEXT_PUBLIC_LOCAL_INGRESS_PORT=19800

RUN npm config set registry "$NPM_REGISTRY" \
    && npm install -g pnpm@11.12.0 --no-audit --no-fund --loglevel=error \
    && pnpm config set registry "$NPM_REGISTRY"
WORKDIR /app/frontend
COPY frontend/package.json frontend/pnpm-lock.yaml frontend/pnpm-workspace.yaml ./
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --reporter=append-only --network-concurrency=4 --fetch-retries=5 --fetch-timeout=120000
COPY frontend ./
RUN pnpm exec next build

USER node
EXPOSE 19806
CMD ["sh", "-c", "pnpm exec next start --hostname 0.0.0.0 --port ${OCTO_FRONTEND_PORT:-19806}"]
