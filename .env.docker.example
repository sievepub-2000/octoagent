# OctoAgent Docker runtime environment. Copy to .env.docker before starting.
COMPOSE_PROJECT_NAME=octoagent
OCTOAGENT_IMAGE_TAG=local

# Container identity. The POSIX installer replaces these with the invoking
# user's IDs so bind-mounted configuration and workspace files stay editable.
OCTOAGENT_UID=1000
OCTOAGENT_GID=1000
OCTOAGENT_DOCKER_GID=0

# Optional base-image overrides for air-gapped, mirrored, or regional registries.
# Example: OCTOAGENT_NGINX_IMAGE=mirror.example.com/library/nginx:1.27-alpine
OCTOAGENT_POSTGRES_IMAGE=postgres:16-alpine
OCTOAGENT_REDIS_IMAGE=redis:7-alpine
OCTOAGENT_NGINX_IMAGE=nginx:1.27-alpine
OCTOAGENT_PYTHON_BASE_IMAGE=python:3.12-slim
OCTOAGENT_NODE_RUNTIME_IMAGE=node:22-bookworm-slim
OCTOAGENT_NODE_FRONTEND_IMAGE=node:22-alpine

# Public ingress and internal service ports.
OCTO_NGINX_PORT=19800
OCTO_GATEWAY_PORT=19802
OCTO_LANGGRAPH_PORT=19804
OCTO_FRONTEND_PORT=19806
OCTO_LANGGRAPH_JOBS=4

# Database sidecars used by the packaged Docker profile.
POSTGRES_DB=octoagent
POSTGRES_PASSWORD=octoagent-change-me

# Required by Better Auth / Next.js production runtime. The installer replaces this.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_BASE_URL=http://localhost:19800

# Optional model/provider credentials. Leave empty for configuration through the WebUI.
OCTOAGENT_MODEL_AUTH_OPENROUTER=
OCTOAGENT_MODEL_AUTH_OPENAI=
OCTOAGENT_MODEL_AUTH_ANTHROPIC=
OCTOAGENT_MODEL_AUTH_DEEPSEEK=
OCTOAGENT_MODEL_AUTH_QWEN=

# Optional outbound proxy for model/search providers. Set upper- and lower-case
# variants for libraries that only honor one convention. Keep internal Docker
# service names in NO_PROXY.
HTTP_PROXY=
HTTPS_PROXY=
http_proxy=
https_proxy=
NO_PROXY=localhost,127.0.0.1,::1,gateway,langgraph,postgres,redis,host.docker.internal
no_proxy=localhost,127.0.0.1,::1,gateway,langgraph,postgres,redis,host.docker.internal

# OpenRouter app attribution and usage accounting opt-in.
OCTOAGENT_OPENROUTER_APP_URL=https://github.com/sievepub-2000/octoagent
OCTOAGENT_OPENROUTER_APP_TITLE=OctoAgent
OCTOAGENT_OPENROUTER_USAGE_INCLUDE=true

# Optional search/data-provider keys.
TAVILY_API_KEY=
JINA_API_KEY=
INFOQUEST_API_KEY=

# Operator/security tokens. The installer leaves them blank unless you set them.
OCTO_OPERATOR_TOKEN=
OCTO_EXECUTION_WORKER_TOKEN=
OCTO_OPERATOR_AUDIT_SECRET=
OCTO_AUTH_DEV_EXPOSE_CODES=0
OCTO_GENERIC_AGENT_ENABLED=1
OCTO_GENERIC_AGENT_INTERVAL_SECONDS=1800
OCTO_GENERIC_AGENT_STARTUP_DELAY_SECONDS=120
